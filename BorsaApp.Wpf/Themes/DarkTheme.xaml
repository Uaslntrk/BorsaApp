<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Dark Theme Colors -->
    <SolidColorBrush x:Key="WindowBackgroundBrush"                   Color="#0A0E1A"/>
    <SolidColorBrush x:Key="PanelBackgroundBrush"                    Color="#111827"/>
    <SolidColorBrush x:Key="SidebarBackgroundBrush"                  Color="#080C16"/>
    <SolidColorBrush x:Key="SidebarTextBrush"                        Color="#F1F5F9"/>

    <SolidColorBrush x:Key="PrimaryTextBrush"                        Color="#E2E8F0"/>
    <SolidColorBrush x:Key="SecondaryTextBrush"                      Color="#64748B"/>

    <SolidColorBrush x:Key="BorderBrushColor"                        Color="#1E293B"/>

    <!-- Inputs -->
    <SolidColorBrush x:Key="InputBackgroundBrush"                    Color="#1E293B"/>
    <SolidColorBrush x:Key="InputTextBrush"                          Color="#E2E8F0"/>

    <!-- DataGrid -->
    <SolidColorBrush x:Key="DataGridHeaderBackgroundBrush"           Color="#0F172A"/>
    <SolidColorBrush x:Key="DataGridBackgroundBrush"                 Color="#111827"/>
    <SolidColorBrush x:Key="DataGridRowBackgroundBrush"              Color="#111827"/>
    <SolidColorBrush x:Key="DataGridAlternatingRowBackgroundBrush"   Color="#1E293B"/>

    <!-- Nav -->
    <SolidColorBrush x:Key="NavHoverBrush"                           Color="#111827"/>
    <SolidColorBrush x:Key="NavActiveBrush"                          Color="#1E293B"/>
</ResourceDictionary>
