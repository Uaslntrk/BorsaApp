<Window x:Class="BorsaApp.Wpf.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BorsaApp — Giriş" Height="420" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0D1117">

    <Grid>
        <!-- Background gradient -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#0D1117" Offset="0"/>
                <GradientStop Color="#161B22" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Border VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="320"
                Background="#161B22"
                BorderBrush="#30363D"
                BorderThickness="1"
                CornerRadius="16"
                Padding="32">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="4" Opacity="0.4" Direction="270"/>
            </Border.Effect>

            <StackPanel>
                <!-- Logo / Brand -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,28">
                    <Border Width="52" Height="52" Background="#4F6EF7" CornerRadius="14"
                            HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="B" FontSize="28" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="BorsaApp" FontSize="20" FontWeight="Bold"
                               Foreground="#E2E8F0" HorizontalAlignment="Center"/>
                    <TextBlock Text="Portföy Yönetim Sistemi" FontSize="12"
                               Foreground="#8B949E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Username -->
                <TextBlock Text="KULLANICI ADI" FontSize="11" FontWeight="SemiBold"
                           Foreground="#8B949E" Margin="0,0,0,6"/>
                <TextBox x:Name="UsernameBox"
                         Background="#21262D"
                         Foreground="#E2E8F0"
                         BorderBrush="#30363D"
                         BorderThickness="1"
                         Padding="12,8"
                         FontSize="13"
                         Height="38"
                         Margin="0,0,0,14"/>

                <!-- Password -->
                <TextBlock Text="ŞİFRE" FontSize="11" FontWeight="SemiBold"
                           Foreground="#8B949E" Margin="0,0,0,6"/>
                <PasswordBox x:Name="PasswordBox"
                             Background="#21262D"
                             Foreground="#E2E8F0"
                             BorderBrush="#30363D"
                             BorderThickness="1"
                             Padding="12,8"
                             FontSize="13"
                             Height="38"
                             Margin="0,0,0,6"/>

                <!-- Error message -->
                <TextBlock x:Name="Msg" Foreground="#EF4444" FontSize="12"
                           Margin="0,4,0,16" TextWrapping="Wrap"/>

                <!-- Login Button -->
                <Button Height="40"
                        Content="Giriş Yap"
                        Click="OnLogin"
                        Background="#4F6EF7"
                        Foreground="White"
                        BorderThickness="0"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#3A57E8"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#2A42C8"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
