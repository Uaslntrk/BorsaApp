<Window x:Class="BorsaApp.Wpf.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BorsaApp — Giriş" Height="560" Width="900"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#080C16">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Left panel -->
            <ColumnDefinition Width="380"/>
            <!-- Right form -->
        </Grid.ColumnDefinitions>

        <!-- ─── LEFT PANEL: Branding ─── -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0A0E1A" Offset="0"/>
                    <GradientStop Color="#111827" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <!-- Decorative circles -->
                <Ellipse Width="400" Height="400"
                         HorizontalAlignment="Left" VerticalAlignment="Top"
                         Margin="-150,-150,0,0" Opacity="0.06">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#4F6EF7" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Width="300" Height="300"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                         Margin="0,0,-100,-100" Opacity="0.08">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#7C3AED" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">

                    <!-- Logo -->
                    <Border Width="64" Height="64" CornerRadius="18"
                            HorizontalAlignment="Left" Margin="0,0,0,24">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4F6EF7" Offset="0"/>
                                <GradientStop Color="#7C3AED" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect Color="#4F6EF7" BlurRadius="20" ShadowDepth="0" Opacity="0.5"/>
                        </Border.Effect>
                        <TextBlock Text="B" FontSize="32" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="BorsaApp" FontSize="32" FontWeight="Bold"
                               Foreground="#F1F5F9" Margin="0,0,0,8"/>
                    <TextBlock Text="Profesyonel Portföy Yönetim Sistemi"
                               FontSize="15" Foreground="#64748B" Margin="0,0,0,36"/>

                    <!-- Feature List -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#1E293B" Margin="0,0,12,0">
                                <TextBlock Text="📈" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Canlı Piyasa Takibi" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#E2E8F0"/>
                                <TextBlock Text="Gerçek zamanlı fiyat güncellemeleri"
                                           FontSize="12" Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#1E293B" Margin="0,0,12,0">
                                <TextBlock Text="💼" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Portföy Analizi" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#E2E8F0"/>
                                <TextBlock Text="Detaylı P/L raporlama ve grafikler"
                                           FontSize="12" Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="8" Background="#1E293B" Margin="0,0,12,0">
                                <TextBlock Text="🔔" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Akıllı Alarmlar" FontSize="13" FontWeight="SemiBold"
                                           Foreground="#E2E8F0"/>
                                <TextBlock Text="Otomatik fiyat alarmı ve bildirim"
                                           FontSize="12" Foreground="#64748B"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── RIGHT PANEL: Form ─── -->
        <Border Grid.Column="1"
                Background="#111827"
                BorderBrush="#1E293B"
                BorderThickness="1,0,0,0">
            <Grid>
                <!-- Login Panel -->
                <StackPanel x:Name="LoginPanel"
                            VerticalAlignment="Center"
                            Margin="40,0">

                    <TextBlock Text="Tekrar Hoş Geldiniz 👋"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#F1F5F9" Margin="0,0,0,6"/>
                    <TextBlock Text="Hesabınıza giriş yapın"
                               FontSize="14" Foreground="#64748B" Margin="0,0,0,32"/>

                    <!-- Username -->
                    <TextBlock Text="KULLANICI ADI" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="0,0,0,6"/>
                    <TextBox x:Name="UsernameBox"
                             Padding="14,10"
                             FontSize="14"
                             Height="44"
                             Margin="0,0,0,16"/>

                    <!-- Password -->
                    <TextBlock Text="ŞİFRE" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Padding="14,10"
                                 FontSize="14"
                                 Height="44"
                                 Margin="0,0,0,8"/>

                    <!-- Error -->
                    <TextBlock x:Name="Msg" Foreground="#EF4444" FontSize="12"
                               Margin="0,4,0,16" TextWrapping="Wrap"/>

                    <!-- Login Button -->
                    <Button Height="46"
                            Click="OnLogin"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,0,20">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#4F6EF7" Offset="0"/>
                                            <GradientStop Color="#7C3AED" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#4F6EF7" BlurRadius="14"
                                                          ShadowDepth="0" Opacity="0.4"/>
                                    </Border.Effect>
                                    <TextBlock Text="Giriş Yap" FontSize="14" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Switch to Register -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Hesabınız yok mu? " FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="Kayıt Ol" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#4F6EF7" Cursor="Hand"
                                   MouseLeftButtonUp="ShowRegister_Click"/>
                    </StackPanel>

                    <!-- Demo credentials -->
                    <Border Background="#1E293B" CornerRadius="8" Padding="12,10" Margin="0,24,0,0">
                        <StackPanel>
                            <TextBlock Text="Demo Giriş Bilgileri" FontSize="11" FontWeight="Bold"
                                       Foreground="#64748B" Margin="0,0,0,6"/>
                            <TextBlock FontSize="12" Foreground="#94A3B8">
                                <Run Text="Admin: " FontWeight="SemiBold"/>
                                <Run Text="admin / admin"/>
                            </TextBlock>
                            <TextBlock FontSize="12" Foreground="#94A3B8" Margin="0,2,0,0">
                                <Run Text="Kullanıcı: " FontWeight="SemiBold"/>
                                <Run Text="user / admin"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Register Panel -->
                <StackPanel x:Name="RegisterPanel"
                            Visibility="Collapsed"
                            VerticalAlignment="Center"
                            Margin="40,0">

                    <TextBlock Text="Hesap Oluştur ✨"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#F1F5F9" Margin="0,0,0,6"/>
                    <TextBlock Text="Yeni kullanıcı kaydı (Sadece Admin)"
                               FontSize="13" Foreground="#64748B" Margin="0,0,0,28"/>

                    <!-- Full Name -->
                    <TextBlock Text="KULLANICI ADI" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="0,0,0,6"/>
                    <Border Background="#1E293B" CornerRadius="8" BorderBrush="#2D3748"
                            BorderThickness="1" Margin="0,0,0,14">
                        <TextBox x:Name="RegUsernameBox"
                                 Padding="14,10"
                                 FontSize="14"
                                 Height="44"/>
                    </Border>

                    <!-- Role -->
                    <TextBlock Text="ROL" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="0,0,0,6"/>
                    <Border Background="#1E293B" CornerRadius="8" BorderBrush="#2D3748"
                            BorderThickness="1" Margin="0,0,0,14">
                        <ComboBox x:Name="RegRoleBox"
                                  Background="Transparent" Foreground="#E2E8F0"
                                  BorderThickness="0" Padding="14,0"
                                  FontSize="14" Height="44">
                            <ComboBoxItem Content="Admin"/>
                            <ComboBoxItem Content="Customer" IsSelected="True"/>
                        </ComboBox>
                    </Border>

                    <!-- Password -->
                    <TextBlock Text="ŞİFRE" FontSize="11" FontWeight="SemiBold"
                               Foreground="#64748B" Margin="0,0,0,6"/>
                    <Border Background="#1E293B" CornerRadius="8" BorderBrush="#2D3748"
                            BorderThickness="1" Margin="0,0,0,8">
                        <PasswordBox x:Name="RegPasswordBox"
                                     Padding="14,10"
                                     FontSize="14"
                                     Height="44"/>
                    </Border>

                    <!-- Reg Error -->
                    <TextBlock x:Name="RegMsg" Foreground="#EF4444" FontSize="12"
                               Margin="0,4,0,16" TextWrapping="Wrap"/>

                    <!-- Register Button -->
                    <Button Height="46"
                            Click="OnRegister_Click"
                            BorderThickness="0" Cursor="Hand" Margin="0,0,0,18">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#10B981" Offset="0"/>
                                            <GradientStop Color="#059669" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="Kayıt Ol" FontSize="14" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Back to Login -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="Zaten hesabınız var mı? " FontSize="13" Foreground="#64748B"/>
                        <TextBlock Text="Giriş Yap" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#4F6EF7" Cursor="Hand"
                                   MouseLeftButtonUp="ShowLogin_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
