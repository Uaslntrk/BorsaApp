<UserControl x:Class="BorsaApp.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BorsaApp.Wpf.ViewModels"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <UserControl.DataContext>
        <vm:DashboardViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="Auto"/>
            <!-- Stat Cards -->
            <RowDefinition Height="*"/>
            <!-- Tables -->
            <RowDefinition Height="1.6*"/>
            <!-- Charts -->
            <RowDefinition Height="Auto"/>
            <!-- News Ticker -->
        </Grid.RowDefinitions>

        <!-- ─── Toolbar ─── -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrushColor}"
                BorderThickness="1" CornerRadius="10" Padding="16,10"
                Margin="0,0,0,14">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.07" Direction="270"/>
            </Border.Effect>
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <TextBlock Text="📊" FontSize="18" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Dashboard" Style="{StaticResource SectionTitle}" Margin="0"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Başlangıç:" VerticalAlignment="Center" Margin="0,0,6,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                    <DatePicker SelectedDate="{Binding FromDate}" Width="120"/>
                    <TextBlock Text="Bitiş:" VerticalAlignment="Center" Margin="14,0,6,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                    <DatePicker SelectedDate="{Binding ToDate}" Width="120"/>
                    <Button Content="Yenile" Command="{Binding RefreshCommand}" Margin="14,0,0,0" Width="80"/>
                    <ToggleButton Content="▶  Piyasa" IsChecked="{Binding IsMarketLive, Mode=TwoWay}"
                                  Command="{Binding ToggleMarketCommand}" Margin="10,0,0,0" Width="100"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── Stat Cards ─── -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,14">
            <!-- Aktif Müşteri -->
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="Aktif Müşteri" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding ActiveCustomerCount}" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="müşteri" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Nakit -->
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="Toplam Nakit" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding TotalCashBalance, StringFormat=C2, ConverterCulture='tr-TR'}"
                               FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="bakiye" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Hisse -->
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="Hisse Portföyü" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding TotalMarketValue, StringFormat=C2, ConverterCulture='tr-TR'}"
                               FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="piyasa değeri" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Unrealized P/L -->
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="Unrealized P/L" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding TotalUnrealizedPL, StringFormat=N2}"
                               FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding TotalUnrealizedPLPct, StringFormat='{}{0:N2}%'}"
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Realized P/L -->
            <Border Style="{StaticResource StatCard}" Margin="0">
                <StackPanel>
                    <TextBlock Text="Realized P/L" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding TotalRealizedPL}"
                               FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="gerçekleşen" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ─── Winners / Losers Tables ─── -->
        <Grid Grid.Row="2" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource FormCard}" Margin="0,0,7,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="🏆" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="En Çok Kazandıranlar (Top 5)" Style="{StaticResource SectionTitle}" Margin="0"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Winners}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Müşteri" Binding="{Binding CustomerName}" Width="*"/>
                            <DataGridTextColumn Header="Kod" Binding="{Binding AssetCode}" Width="80"/>
                            <DataGridTextColumn Header="P/L" Binding="{Binding UnrealizedPL, StringFormat=N2}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{StaticResource PriceUpBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource FormCard}" Margin="7,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="📉" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="En Çok Kaybettirenler (Top 5)" Style="{StaticResource SectionTitle}" Margin="0"/>
                    </StackPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Losers}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Müşteri" Binding="{Binding CustomerName}" Width="*"/>
                            <DataGridTextColumn Header="Kod" Binding="{Binding AssetCode}" Width="80"/>
                            <DataGridTextColumn Header="P/L" Binding="{Binding UnrealizedPL, StringFormat=N2}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{StaticResource PriceDownBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ─── Charts ─── -->
        <Grid Grid.Row="3" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1.6*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource FormCard}" Margin="0,0,7,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="🍕" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Portföy Dağılımı" Style="{StaticResource SectionTitle}" Margin="0"/>
                    </StackPanel>
                    <lvc:PieChart Grid.Row="1" Series="{Binding AssetDistributionSeries}" LegendPosition="Right"/>
                </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource FormCard}" Margin="7,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="📊" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Unrealized P/L Grafiği (Winners &amp; Losers)" Style="{StaticResource SectionTitle}" Margin="0"/>
                    </StackPanel>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding PLSeries}" XAxes="{Binding XAxes}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ─── News Ticker ─── -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#1A1A2E"
                    CornerRadius="8" Padding="14,10">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#EF4444" CornerRadius="4" Padding="6,3" Margin="0,0,12,0">
                        <TextBlock Text="SON DAKİKA" Foreground="White" FontWeight="Bold" FontSize="11"/>
                    </Border>
                    <TextBlock Text="{Binding CurrentNewsText}" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <TextBlock Grid.Column="1" Text="{Binding Message}" Foreground="{StaticResource DangerBrush}"
                       Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="300" FontSize="12"/>
        </Grid>
    </Grid>
</UserControl>
