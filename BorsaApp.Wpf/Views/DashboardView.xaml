<UserControl x:Class="BorsaApp.Wpf.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BorsaApp.Wpf.ViewModels"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF">

    <UserControl.DataContext>
        <vm:DashboardViewModel/>
    </UserControl.DataContext>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Filters/Summary -->
            <RowDefinition Height="Auto"/> <!-- Stat Cards -->
            <RowDefinition Height="*"/>    <!-- Main Content (Tables/Charts) -->
            <RowDefinition Height="Auto"/> <!-- News Ticker -->
        </Grid.RowDefinitions>

        <!-- ─── HEADER & FILTERS ─── -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Piyasa Özeti" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Border Background="{DynamicResource InputBackgroundBrush}" CornerRadius="12" Padding="8,4" Margin="16,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Canlı Veri" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Border Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="10" Padding="12,6" BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Tarih Aralığı:" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                        <DatePicker SelectedDate="{Binding FromDate}" Width="110" Style="{StaticResource {x:Type DatePicker}}"/>
                        <TextBlock Text="—" VerticalAlignment="Center" Margin="8,0" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <DatePicker SelectedDate="{Binding ToDate}" Width="110"/>
                    </StackPanel>
                </Border>
                <Button Content="Yenile" Command="{Binding RefreshCommand}" Margin="12,0,0,0" Width="80" Height="36"/>
            </StackPanel>
        </Grid>

        <!-- ─── STAT CARDS ─── -->
        <UniformGrid Grid.Row="1" Columns="5" Margin="0,0,0,24">
            <!-- Total Value -->
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="Toplam Piyasa Değeri" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding TotalMarketValue, StringFormat=C0, ConverterCulture='tr-TR'}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4,0,0"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="↗ 2.4%" Foreground="#10B981" FontSize="11" FontWeight="SemiBold"/>
                        <TextBlock Text=" bu ay" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="4,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Cash -->
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="Kullanılabilir Nakit" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding TotalCashBalance, StringFormat=C0, ConverterCulture='tr-TR'}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="Yatırıma hazır" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Unrealized P/L -->
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="Bekleyen Kar/Zarar" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding TotalUnrealizedPL, StringFormat=N0}" FontSize="22" FontWeight="Bold" 
                               Foreground="{Binding TotalUnrealizedPL, Converter={StaticResource ProfitLossColorConverter}}" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding TotalUnrealizedPLPct, StringFormat='{}{0:N2}%'}" 
                               Foreground="{Binding TotalUnrealizedPL, Converter={StaticResource ProfitLossColorConverter}}" FontSize="11" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Realized P/L -->
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="Gerçekleşen Kar/Zarar" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding TotalRealizedPL, StringFormat=N0}" FontSize="22" FontWeight="Bold" 
                               Foreground="{Binding TotalRealizedPL, Converter={StaticResource ProfitLossColorConverter}}" Margin="0,4,0,0"/>
                    <TextBlock Text="Toplam dönem" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Customers -->
            <Border Style="{StaticResource StatCard}" Margin="0">
                <StackPanel>
                    <TextBlock Text="Aktif Müşteri" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding ActiveCustomerCount}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4,0,0"/>
                    <TextBlock Text="Yönetilen portföy" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- ─── MAIN CONTENT ─── -->
        <Grid Grid.Row="2" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Portfolio Distribution (Pie) -->
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource FormCard}" Margin="0,0,12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Portföy Dağılımı (Sektör bazlı)" Style="{StaticResource SectionTitle}"/>
                    <lvc:PieChart Grid.Row="1" Series="{Binding AssetDistributionSeries}" LegendPosition="Right" 
                                  InitialRotation="-90" MaxAngle="360"/>
                </Grid>
            </Border>

            <!-- P/L History (Column) -->
            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource FormCard}" Margin="12,0,0,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Müşteri Bazlı Performans" Style="{StaticResource SectionTitle}"/>
                    <lvc:CartesianChart Grid.Row="1" Series="{Binding PLSeries}" XAxes="{Binding XAxes}"/>
                </Grid>
            </Border>

            <!-- Winners Table -->
            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource FormCard}" Margin="0,12,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <TextBlock Text="En Çok Kazandıranlar" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                        <Border Background="#10B981" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" Margin="0,0,0,10">
                            <TextBlock Text="TOP 5" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </DockPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Winners}" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Müşteri" Binding="{Binding CustomerName}" Width="*"/>
                            <DataGridTextColumn Header="Hisse" Binding="{Binding AssetCode}" Width="80"/>
                            <DataGridTextColumn Header="Kar/Zarar" Binding="{Binding UnrealizedPL, StringFormat=N2}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#10B981"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Losers Table -->
            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource FormCard}" Margin="12,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel>
                        <TextBlock Text="En Çok Kaybettirenler" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                        <Border Background="#EF4444" CornerRadius="4" Padding="6,2" HorizontalAlignment="Right" Margin="0,0,0,10">
                            <TextBlock Text="TOP 5" Foreground="White" FontSize="10" FontWeight="Bold"/>
                        </Border>
                    </DockPanel>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding Losers}" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Müşteri" Binding="{Binding CustomerName}" Width="*"/>
                            <DataGridTextColumn Header="Hisse" Binding="{Binding AssetCode}" Width="80"/>
                            <DataGridTextColumn Header="Kar/Zarar" Binding="{Binding UnrealizedPL, StringFormat=N2}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#EF4444"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ─── NEWS TICKER ─── -->
        <Border Grid.Row="3" Background="{DynamicResource PanelBackgroundBrush}" CornerRadius="12" Padding="20,12" BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="1">
            <DockPanel>
                <Border Background="#4F6EF7" CornerRadius="6" Padding="8,4" Margin="0,0,16,0">
                    <TextBlock Text="HABERLER" Foreground="White" FontSize="11" FontWeight="Bold"/>
                </Border>
                <TextBlock Text="{Binding CurrentNewsText}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
