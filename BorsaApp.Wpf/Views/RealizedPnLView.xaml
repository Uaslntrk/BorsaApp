<UserControl x:Class="BorsaApp.Wpf.Views.RealizedPnLView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BorsaApp.Wpf.ViewModels">

    <UserControl.DataContext>
        <vm:RealizedPnLViewModel/>
    </UserControl.DataContext>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Grid -->
            <RowDefinition Height="Auto"/> <!-- Summary Bar -->
        </Grid.RowDefinitions>

        <!-- ─── TOOLBAR & FILTERS ─── -->
        <Border Grid.Row="0" Style="{StaticResource FormCard}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <StackPanel Orientation="Vertical" Margin="0,0,24,0">
                        <TextBlock Text="MÜŞTERİ" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                        <ComboBox Width="200" ItemsSource="{Binding CustomerOptions}" SelectedItem="{Binding SelectedCustomer}" DisplayMemberPath="Name"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Margin="0,0,24,0">
                        <TextBlock Text="DÖNEM SEÇİMİ" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <DatePicker SelectedDate="{Binding FromDate}" Width="120"/>
                            <TextBlock Text="—" VerticalAlignment="Center" Margin="8,0" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <DatePicker SelectedDate="{Binding ToDate}" Width="120"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Yenile" Command="{Binding RefreshCommand}" Width="90" Height="36" Margin="0,0,12,0"/>
                    <Button Content="📊 Excel" Command="{Binding ExportExcelCommand}" Width="100" Height="36" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="📄 PDF" Command="{Binding ExportPdfCommand}" Width="85" Height="36" Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── REALIZED P/L GRID ─── -->
        <Border Grid.Row="1" Style="{StaticResource FormCard}" Margin="0,0,0,20">
            <DataGrid ItemsSource="{Binding Rows}" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="İşlem Zamanı" Binding="{Binding TradeDate, StringFormat='dd.MM.yyyy HH:mm'}" Width="140" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    
                    <DataGridTextColumn Header="Müşteri" Binding="{Binding CustomerName}" Width="*"/>
                    
                    <DataGridTemplateColumn Header="Enstrüman" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SidebarBackgroundBrush}" CornerRadius="8" Padding="8,2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding AssetCode}" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Lot" Binding="{Binding SellQty, StringFormat=N0}" Width="80">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Satış Fiyatı" Binding="{Binding SellPrice, StringFormat=N4}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,12,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Ort. Maliyet" Binding="{Binding AvgCostAtSell, StringFormat=N4}" Width="100">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,12,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Realized P/L" Binding="{Binding RealizedPL, StringFormat=N2}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,12,0"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="{Binding RealizedPL, Converter={StaticResource ProfitLossColorConverter}}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="Kar/Zarar %" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="10" Padding="8,2" HorizontalAlignment="Right" Margin="0,0,12,0" Background="{Binding RealizedPL, Converter={StaticResource ProfitLossAlphaBrushConverter}}">
                                    <TextBlock Text="{Binding RealizedPLPct, StringFormat='{}{0:N2}%'}" FontWeight="Bold" Foreground="{Binding RealizedPL, Converter={StaticResource ProfitLossColorConverter}}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ─── SUMMARY BAR ─── -->
        <Border Grid.Row="2" Style="{StaticResource StatCard}" Margin="0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4">
                <TextBlock Text="DÖNEM TOPLAM REALIZED P/L:" Style="{StaticResource FormLabel}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock Text="{Binding TotalRealized, StringFormat=N2}" FontSize="24" FontWeight="Bold" 
                           Foreground="{Binding TotalRealized, Converter={StaticResource ProfitLossColorConverter}}" VerticalAlignment="Center"/>
                <TextBlock Text=" ₺" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
