<UserControl x:Class="BorsaApp.Wpf.Views.AlarmsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BorsaApp.Wpf.ViewModels"
             xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <UserControl.DataContext>
        <vm:AlarmsViewModel/>
    </UserControl.DataContext>

    <Grid Margin="24,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ─── ALARM LIST (Left) ─── -->
        <Border Grid.Column="0" Style="{StaticResource FormCard}" Margin="0,0,20,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Fiyat Alarmları" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                    <Button Content="🔄 Yenile" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}" 
                            HorizontalAlignment="Right" Width="80" Height="30"/>
                </DockPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Alarms}" SelectedItem="{Binding Selected}" 
                          AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Enstrüman" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SidebarBackgroundBrush}" CornerRadius="8" Padding="8,4" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding AssetCode}" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Hedef Fiyat" Binding="{Binding TargetPrice, StringFormat=N2}" Width="110">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0,0,12,0"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Yön" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Direction}" Value="Above">
                                                        <Setter Property="Text" Value="YUKARI ▲"/>
                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Direction}" Value="Below">
                                                        <Setter Property="Text" Value="AŞAĞI ▼"/>
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Oto İşlem" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="6,2" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsAutoSell}" Value="True">
                                                        <Setter Property="Background" Value="#204F6EF7"/>
                                                        <Setter Property="BorderBrush" Value="#4F6EF7"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsAutoSell}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="AKTİF" FontSize="10" FontWeight="Bold" Foreground="#4F6EF7"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Oluşturulma" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" Width="140" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        
                        <DataGridTemplateColumn Header="Durum" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TriggeredAt}" Value="{x:Null}">
                                                        <Setter Property="Text" Value="Beklemede"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                                <Setter Property="Text" Value="{Binding TriggeredAt, StringFormat='🚨 Tetiklendi: {0:dd.MM.yyyy HH:mm}'}"/>
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ─── ALARM FORM (Right) ─── -->
        <Border Grid.Column="1" Style="{StaticResource FormCard}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Alarm Tanımla" Style="{StaticResource SectionTitle}" Margin="0,0,0,16"/>
                    
                    <TextBlock Text="HİSSE KODU" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Form.AssetCode, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,0,0,16"/>

                    <TextBlock Text="HEDEF FİYAT" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Form.TargetPrice, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,0,0,16"/>

                    <TextBlock Text="KOŞUL" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                    <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding Form.Direction, Mode=TwoWay}" Height="38" Margin="0,0,0,24">
                        <ComboBoxItem Tag="Above" IsSelected="True">Fiyat Üzerine Çıkınca</ComboBoxItem>
                        <ComboBoxItem Tag="Below">Fiyat Altına Düşünce</ComboBoxItem>
                    </ComboBox>

                    <Border Background="{DynamicResource SidebarBackgroundBrush}" CornerRadius="12" Padding="14,12" Margin="0,0,0,20">
                        <StackPanel>
                            <CheckBox x:Name="AutoTradeCheck" Content="Otomatik Al/Sat Tetiklensin" IsChecked="{Binding Form.IsAutoSell}" Margin="0,0,0,12"/>
                            
                            <StackPanel Visibility="{Binding IsChecked, ElementName=AutoTradeCheck, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="MÜŞTERİ (OTO İŞLEM İÇİN)" Style="{StaticResource FormLabel}" Margin="0,4,0,6"/>
                                <ComboBox ItemsSource="{Binding Customers}" SelectedItem="{Binding SelectedCustomer}" DisplayMemberPath="Name" Height="38"/>
                                <TextBlock Text="* Alarm tetiklendiğinde müşterinin bakiyesi varsa otomatik işlem açılır." FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}" Margin="2,6,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Button Content="➕ Alarm Oluştur" Command="{Binding CreateCommand}" Height="46" Margin="0,0,0,12">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" CornerRadius="10">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#4F6EF7" Offset="0"/>
                                            <GradientStop Color="#7C3AED" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <TextBlock Text="{TemplateBinding Content}" FontSize="14" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.9"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Content="🗑️ Seçili Alarmı Sil" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Height="36"/>

                    <TextBlock Text="{Binding Message}" Foreground="{StaticResource SuccessBrush}" FontSize="12" Margin="0,16,0,0" 
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
