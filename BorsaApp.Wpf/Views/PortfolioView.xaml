<UserControl x:Class="BorsaApp.Wpf.Views.PortfolioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BorsaApp.Wpf.ViewModels">

    <UserControl.DataContext>
        <vm:PortfolioViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <!-- Toolbar -->
            <RowDefinition Height="*"/>
            <!-- DataGrid -->
            <RowDefinition Height="Auto"/>
            <!-- Summary Bar -->
            <RowDefinition Height="Auto"/>
            <!-- Status -->
        </Grid.RowDefinitions>

        <!-- Page Title -->
        <TextBlock Grid.Row="0" Style="{StaticResource PageTitle}" Text="💼  Portföy"/>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource FormCard}" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Başlangıç:" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,0,6,0"/>
                <DatePicker SelectedDate="{Binding FromDate}" Width="130"/>
                <TextBlock Text="Bitiş:" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="14,0,6,0"/>
                <DatePicker SelectedDate="{Binding ToDate}" Width="130"/>
                <TextBlock Text="Müşteri:" VerticalAlignment="Center"
                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="14,0,6,0"/>
                <ComboBox Width="220"
                          ItemsSource="{Binding CustomerOptions}"
                          SelectedItem="{Binding SelectedCustomer}"
                          DisplayMemberPath="Name"/>
                <Button Content="Yenile"        Command="{Binding RefreshCommand}"     Margin="12,0,0,0" Width="80"/>
                <Button Content="📊 Excel"      Command="{Binding ExportExcelCommand}" Margin="8,0,0,0"  Width="90"
                        Style="{StaticResource SecondaryButton}"/>
                <Button Content="📄 PDF"        Command="{Binding ExportPdfCommand}"   Margin="8,0,0,0"  Width="72"
                        Style="{StaticResource SecondaryButton}"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <Border Grid.Row="2" Style="{StaticResource FormCard}" Margin="0,0,0,12">
            <DataGrid ItemsSource="{Binding Positions}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Müşteri"      Binding="{Binding CustomerName}"  Width="*"/>
                    <DataGridTextColumn Header="Kod"          Binding="{Binding AssetCode}"     Width="90"/>
                    <DataGridTextColumn Header="Net Lot"      Binding="{Binding NetQty}"        Width="80"/>
                    <DataGridTextColumn Header="Ort. Maliyet" Binding="{Binding AvgCost}"       Width="110"/>
                    <DataGridTextColumn Header="Güncel"       Binding="{Binding CurrentPrice}"  Width="90"/>
                    <DataGridTextColumn Header="Maliyet"      Binding="{Binding CostValue}"     Width="110"/>
                    <DataGridTextColumn Header="Piyasa"       Binding="{Binding MarketValue}"   Width="110"/>
                    <DataGridTextColumn Header="P/L"          Binding="{Binding UnrealizedPL}"  Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="P/L %"        Binding="{Binding UnrealizedPLPct}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Summary Cards -->
        <UniformGrid Grid.Row="3" Columns="4" Margin="0,0,0,8">
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource FormLabel}" Text="TOPLAM MALİYET"/>
                    <TextBlock Text="{Binding TotalCost}" FontSize="16" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource FormLabel}" Text="TOPLAM PİYASA"/>
                    <TextBlock Text="{Binding TotalMarket}" FontSize="16" FontWeight="Bold" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource FormLabel}" Text="TOPLAM P/L"/>
                    <TextBlock Text="{Binding TotalPL}" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="0">
                <StackPanel>
                    <TextBlock Style="{StaticResource FormLabel}" Text="TOPLAM P/L %"/>
                    <TextBlock Text="{Binding TotalPLPct}" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <TextBlock Grid.Row="4" Text="{Binding Message}" Foreground="{StaticResource DangerBrush}"
                   TextWrapping="Wrap" FontSize="12"/>
    </Grid>
</UserControl>
