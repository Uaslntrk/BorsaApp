<UserControl x:Class="BorsaApp.Wpf.Views.PortfolioView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BorsaApp.Wpf.ViewModels">

    <UserControl.DataContext>
        <vm:PortfolioViewModel/>
    </UserControl.DataContext>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Toolbar -->
            <RowDefinition Height="*"/>    <!-- Grid -->
            <RowDefinition Height="Auto"/> <!-- Summary Bar -->
        </Grid.RowDefinitions>

        <!-- ─── TOOLBAR & FILTERS ─── -->
        <Border Grid.Row="0" Style="{StaticResource FormCard}" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <StackPanel Orientation="Vertical" Margin="0,0,24,0">
                        <TextBlock Text="MÜŞTERİ SEÇİMİ" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                        <ComboBox Width="220" ItemsSource="{Binding CustomerOptions}" SelectedItem="{Binding SelectedCustomer}" DisplayMemberPath="Name"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical" Margin="0,0,24,0">
                        <TextBlock Text="TARİH ARALIĞI" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <DatePicker SelectedDate="{Binding FromDate}" Width="120"/>
                            <TextBlock Text="—" VerticalAlignment="Center" Margin="8,0" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <DatePicker SelectedDate="{Binding ToDate}" Width="120"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Content="Yenile" Command="{Binding RefreshCommand}" Width="90" Height="36" Margin="0,0,12,0"/>
                    <Button Content="📊 Excel" Command="{Binding ExportExcelCommand}" Width="100" Height="36" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                    <Button Content="📄 PDF" Command="{Binding ExportPdfCommand}" Width="85" Height="36" Style="{StaticResource SecondaryButton}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── PORTFOLIO GRID ─── -->
        <Border Grid.Row="1" Style="{StaticResource FormCard}" Margin="0,0,0,20">
            <DataGrid ItemsSource="{Binding Positions}" AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="Enstrüman" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,4">
                                    <Border Width="32" Height="32" CornerRadius="8" Background="{DynamicResource InputBackgroundBrush}" Margin="0,0,12,0">
                                        <TextBlock Text="{Binding AssetCode, Converter={StaticResource FirstLetterConverter}}" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                                                   FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding AssetCode}" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding AssetName}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Müşteri" Binding="{Binding CustomerName}" Width="*"/>
                    
                    <DataGridTemplateColumn Header="Net Lot" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding NetQty, StringFormat=N0}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="Ort. Maliyet" Binding="{Binding AvgCost, StringFormat=N4}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,12,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Güncel Fiyat" Binding="{Binding CurrentPrice, StringFormat=N4}" Width="110">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,12,0"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="Kar/Zarar" Binding="{Binding UnrealizedPL, StringFormat=N2}" Width="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Margin" Value="0,0,12,0"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Foreground" Value="{Binding UnrealizedPL, Converter={StaticResource ProfitLossColorConverter}}"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTemplateColumn Header="P/L %" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12" Padding="8,4" HorizontalAlignment="Right" Margin="0,0,12,0" Background="{Binding UnrealizedPL, Converter={StaticResource ProfitLossAlphaBrushConverter}}">
                                    <TextBlock Text="{Binding UnrealizedPLPct, StringFormat='{}{0:N2}%'}" FontWeight="Bold" Foreground="{Binding UnrealizedPL, Converter={StaticResource ProfitLossColorConverter}}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- ─── SUMMARY BAR ─── -->
        <UniformGrid Grid.Row="2" Columns="4">
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="TOPLAM MALİYET" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding TotalCost, StringFormat=C2, ConverterCulture='tr-TR'}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="PİYASA DEĞERİ" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding TotalMarket, StringFormat=C2, ConverterCulture='tr-TR'}" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}">
                <StackPanel>
                    <TextBlock Text="TOPLAM KAR/ZARAR" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding TotalPL, StringFormat=N2}" FontSize="18" FontWeight="Bold" Foreground="{Binding TotalPL, Converter={StaticResource ProfitLossColorConverter}}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCard}" Margin="0">
                <StackPanel>
                    <TextBlock Text="P/L ORANI" Style="{StaticResource FormLabel}"/>
                    <TextBlock Text="{Binding TotalPLPct, StringFormat='{}{0:N2}%'}" FontSize="18" FontWeight="Bold" Foreground="{Binding TotalPL, Converter={StaticResource ProfitLossColorConverter}}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
