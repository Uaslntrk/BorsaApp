<UserControl x:Class="BorsaApp.Wpf.Views.AssetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BorsaApp.Wpf.ViewModels">

    <UserControl.DataContext>
        <vm:AssetsViewModel/>
    </UserControl.DataContext>

    <Grid Margin="20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Page Title -->
        <TextBlock Grid.Row="0" Style="{StaticResource PageTitle}" Text="📈  Enstrüman Yönetimi"/>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*" MinWidth="260"/>
            </Grid.ColumnDefinitions>

            <!-- Liste -->
            <Border Grid.Column="0" Style="{StaticResource FormCard}" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource SectionTitle}" Text="Enstrüman Listesi" Margin="0,0,0,10"/>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Assets}"
                              SelectedItem="{Binding Selected}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id"     Binding="{Binding Id}"      Width="50"/>
                            <DataGridTextColumn Header="Kod"    Binding="{Binding Code}"     Width="90"/>
                            <DataGridTextColumn Header="Ad"     Binding="{Binding Name}"     Width="*"/>
                            <DataGridTextColumn Header="Sektör" Binding="{Binding Sector}"   Width="140"/>
                            <DataGridTextColumn Header="Fiyat"  Binding="{Binding CurrentPrice, StringFormat=N4}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPriceUp}" Value="True">
                                                <Setter Property="Foreground" Value="#10B981"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPriceDown}" Value="True">
                                                <Setter Property="Foreground" Value="#EF4444"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Form -->
            <Border Grid.Column="1" Style="{StaticResource FormCard}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Enstrüman Formu"/>
                    <Separator/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="KOD (örn: THYAO)" Margin="0,10,0,4"/>
                    <TextBox Text="{Binding Form.Code, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="AD" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Form.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="SEKTÖR" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Form.Sector, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                    <TextBlock Style="{StaticResource FormLabel}" Text="GÜNCEL FİYAT" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Form.CurrentPrice, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>

                    <Separator/>

                    <UniformGrid Columns="2" Margin="0,12,0,0">
                        <Button Content="Yenile"  Command="{Binding RefreshCommand}"  Margin="0,0,4,6" Style="{StaticResource SecondaryButton}"/>
                        <Button Content="Temizle" Command="{Binding ClearCommand}"    Margin="4,0,0,6" Style="{StaticResource SecondaryButton}"/>
                        <Button Content="Ekle"    Command="{Binding CreateCommand}"   Margin="0,0,4,0"/>
                        <Button Content="Güncelle" Command="{Binding UpdateCommand}"  Margin="4,0,0,0"/>
                    </UniformGrid>
                    <Button Content="⛔  Sil" Command="{Binding DeleteCommand}"
                            Margin="0,6,0,0" Style="{StaticResource DangerButton}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status -->
        <TextBlock Grid.Row="2" Text="{Binding Message}" Foreground="{StaticResource DangerBrush}"
                   Margin="0,10,0,0" TextWrapping="Wrap" FontSize="12"/>
    </Grid>
</UserControl>
