<UserControl x:Class="BorsaApp.Wpf.Views.AssetsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:BorsaApp.Wpf.ViewModels">

    <UserControl.DataContext>
        <vm:AssetsViewModel/>
    </UserControl.DataContext>

    <Grid Margin="24,20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="320"/>
        </Grid.ColumnDefinitions>

        <!-- ─── ASSET LIST (Left) ─── -->
        <Border Grid.Column="0" Style="{StaticResource FormCard}" Margin="0,0,20,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="Piyasa İzleme" Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                    <Button Content="🔄 Yenile" Command="{Binding RefreshCommand}" Style="{StaticResource SecondaryButton}" 
                            HorizontalAlignment="Right" Width="80" Height="30"/>
                </DockPanel>

                <DataGrid Grid.Row="1" ItemsSource="{Binding Assets}" SelectedItem="{Binding Selected}" 
                          AutoGenerateColumns="False" IsReadOnly="True" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Sembol" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource SidebarBackgroundBrush}" CornerRadius="12" Padding="8,4" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Code}" FontWeight="Bold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Enstrüman Adı" Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel VerticalAlignment="Center" Margin="8,0">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <TextBlock Text="{Binding Sector}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Fiyat" Binding="{Binding CurrentPrice, StringFormat=N4}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Margin" Value="0,0,12,0"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPriceUp}" Value="True">
                                            <Setter Property="Foreground" Value="#10B981"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsPriceDown}" Value="True">
                                            <Setter Property="Foreground" Value="#EF4444"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTemplateColumn Header="Değişim" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPriceUp}" Value="True">
                                                        <Setter Property="Text" Value="▲ 2.1%"/>
                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsPriceDown}" Value="True">
                                                        <Setter Property="Text" Value="▼ 1.4%"/>
                                                        <Setter Property="Foreground" Value="#EF4444"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ─── ASSET FORM (Right) ─── -->
        <Border Grid.Column="1" Style="{StaticResource FormCard}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Enstrüman Detayı" Style="{StaticResource SectionTitle}" Margin="0,0,0,16"/>
                    
                    <TextBlock Text="KOD (Örn: THYAO)" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Form.Code, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,0,0,16" IsEnabled="{Binding Selected, Converter={StaticResource NullToBoolConverter}, ConverterParameter=invert}"/>

                    <TextBlock Text="İSİM" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Form.Name, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,0,0,16"/>

                    <TextBlock Text="SEKTÖR" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Form.Sector, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,0,0,16"/>

                    <TextBlock Text="GÜNCEL FİYAT (₺)" Style="{StaticResource FormLabel}" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Form.CurrentPrice, UpdateSourceTrigger=PropertyChanged}" Height="38" Margin="0,0,0,24"/>

                    <Separator Margin="0,0,0,20"/>

                    <UniformGrid Columns="2" Margin="0,0,0,8">
                        <Button Content="💾 Ekle" Command="{Binding CreateCommand}" Margin="0,0,4,0" Height="40"/>
                        <Button Content="🔄 Güncelle" Command="{Binding UpdateCommand}" Margin="4,0,0,0" Height="40"/>
                    </UniformGrid>
                    
                    <Button Content="Formu Temizle" Command="{Binding ClearCommand}" Style="{StaticResource SecondaryButton}" Height="36" Margin="0,0,0,8"/>
                    
                    <Button Content="🗑️ Enstrümanı Sil" Command="{Binding DeleteCommand}" Style="{StaticResource DangerButton}" Height="36"/>

                    <TextBlock Text="{Binding Message}" Foreground="{StaticResource SuccessBrush}" FontSize="12" Margin="0,12,0,0" 
                               TextWrapping="Wrap" TextAlignment="Center"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
