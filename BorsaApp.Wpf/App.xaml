<Application x:Class="BorsaApp.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BorsaApp.Wpf"
             xmlns:conv="clr-namespace:BorsaApp.Wpf.Converters"
             StartupUri="LoginWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml" />
                <ResourceDictionary Source="Themes/GlobalStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Converters -->
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <conv:StringToVisibilityConverter   x:Key="StringToVisibilityConverter"/>
            <conv:ProfitLossColorConverter      x:Key="ProfitLossColorConverter"/>
            <conv:ProfitLossAlphaBrushConverter x:Key="ProfitLossAlphaBrushConverter"/>
            <conv:FirstLetterConverter          x:Key="FirstLetterConverter"/>
            <conv:NullToBoolConverter           x:Key="NullToBoolConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
