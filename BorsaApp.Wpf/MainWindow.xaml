<Window x:Class="BorsaApp.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BorsaApp.Wpf.Views"
        Title="BorsaApp — Portföy Yönetimi"
        Height="780" Width="1320"
        MinHeight="680" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ─── SIDEBAR ─── -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrushColor}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Brand -->
                    <RowDefinition Height="*"/>
                    <!-- Nav -->
                    <RowDefinition Height="Auto"/>
                    <!-- Bottom -->
                </Grid.RowDefinitions>

                <!-- Brand -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource BorderBrushColor}"
                        BorderThickness="0,0,0,1"
                        Padding="20,22,20,18">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="36" Height="36" CornerRadius="10" Margin="0,0,12,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4F6EF7" Offset="0"/>
                                    <GradientStop Color="#7C3AED" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="B" FontSize="18" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="BorsaApp" FontSize="15" FontWeight="Bold"
                                       Foreground="{DynamicResource SidebarTextBrush}"/>
                            <TextBlock Text="Portföy Sistemi" FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Navigation Items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                    <StackPanel>
                        <TextBlock Text="MENÜ" FontSize="10" FontWeight="Bold" Margin="20,12,0,6"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Opacity="0.6"/>

                        <RadioButton x:Name="NavDashboard"    Style="{StaticResource NavButton}" Content="📊   Dashboard"    IsChecked="True"  GroupName="Nav" Checked="Nav_Checked" Tag="6"/>
                        <RadioButton x:Name="NavMusteriler"   Style="{StaticResource NavButton}" Content="👤   Müşteriler"              GroupName="Nav" Checked="Nav_Checked" Tag="0"/>
                        <RadioButton x:Name="NavEnstrumanlar" Style="{StaticResource NavButton}" Content="📈   Enstrümanlar"            GroupName="Nav" Checked="Nav_Checked" Tag="1"/>
                        <RadioButton x:Name="NavIslemler"     Style="{StaticResource NavButton}" Content="🔄   İşlemler"               GroupName="Nav" Checked="Nav_Checked" Tag="2"/>
                        <RadioButton x:Name="NavPortfoy"      Style="{StaticResource NavButton}" Content="💼   Portföy"                GroupName="Nav" Checked="Nav_Checked" Tag="3"/>
                        <RadioButton x:Name="NavRealizedPL"   Style="{StaticResource NavButton}" Content="💰   Realized P/L"           GroupName="Nav" Checked="Nav_Checked" Tag="4"/>
                        <RadioButton x:Name="NavAlarmlar"     Style="{StaticResource NavButton}" Content="🔔   Alarmlar"               GroupName="Nav" Checked="Nav_Checked" Tag="5"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- Bottom: Theme + User -->
                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource BorderBrushColor}"
                        BorderThickness="0,1,0,0"
                        Padding="14,14">
                    <StackPanel>
                        <!-- Theme Toggle -->
                        <ToggleButton x:Name="ThemeToggleButton"
                                      Content="🌙  Koyu Tema"
                                      Width="192"
                                      HorizontalAlignment="Left"
                                      Click="ThemeToggle_Click"
                                      Margin="0,0,0,10"/>
                        <!-- User info -->
                        <Border Background="{DynamicResource InputBackgroundBrush}"
                                CornerRadius="8" Padding="10,8">
                            <StackPanel Orientation="Horizontal">
                                <Border Width="28" Height="28" CornerRadius="14"
                                        Background="#4F6EF7" Margin="0,0,10,0">
                                    <TextBlock Text="A" FontSize="13" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Admin" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SidebarTextBrush}"/>
                                    <TextBlock Text="Yönetici" FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ─── CONTENT AREA ─── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Top bar -->
                <RowDefinition Height="*"/>
                <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrushColor}"
                    BorderThickness="0,0,0,1"
                    Padding="24,0">
                <Grid Height="52">
                    <TextBlock x:Name="PageTitleText"
                               Text="Dashboard"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>
                    <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{DynamicResource InputBackgroundBrush}"
                                CornerRadius="20" Padding="10,5" Margin="0,0,10,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="●" Foreground="#10B981" FontSize="10"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Canlı Piyasa"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="12"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource InputBackgroundBrush}"
                                CornerRadius="20" Padding="10,5">
                            <TextBlock x:Name="TopBarDate"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontSize="12"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Views via TabControl (hidden header, controlled by sidebar) -->
            <TabControl x:Name="MainTabControl"
                        Grid.Row="1"
                        Margin="0">
                <TabItem x:Name="TabMusteriler"   Header="Müşteriler"><views:CustomersView/></TabItem>
                <TabItem                           Header="Enstrümanlar"><views:AssetsView/></TabItem>
                <TabItem                           Header="İşlemler"><views:TradesView/></TabItem>
                <TabItem                           Header="Portföy"><views:PortfolioView/></TabItem>
                <TabItem                           Header="Realized P/L"><views:RealizedPnLView/></TabItem>
                <TabItem                           Header="Alarmlar"><views:AlarmsView/></TabItem>
                <TabItem                           Header="Dashboard"><views:DashboardView/></TabItem>
            </TabControl>
        </Grid>

        <!-- ─── Toast Notification ─── -->
        <Border x:Name="ToastNotificationBorder"
                Grid.Column="1"
                Background="#1E293B"
                CornerRadius="12"
                Padding="18,14"
                Margin="0,0,24,28"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Visibility="Collapsed"
                Panel.ZIndex="999">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.4" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Width="36" Height="36" Background="#EF4444" CornerRadius="10" Margin="0,0,12,0">
                    <TextBlock Text="🔔" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="ToastMessageText"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="320"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
