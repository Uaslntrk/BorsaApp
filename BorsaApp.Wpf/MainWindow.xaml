<Window x:Class="BorsaApp.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:BorsaApp.Wpf.Views"
        Title="BorsaApp — Portföy Yönetimi"
        Height="720" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ─── Header Bar ─── -->
        <Border Grid.Row="0"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrushColor}"
                BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <!-- App Brand (left) -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Border Width="28" Height="28" Background="#4F6EF7" CornerRadius="6" Margin="0,0,10,0">
                        <TextBlock Text="B" FontSize="15" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="BorsaApp" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Controls (right) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Tema:" VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,8,0" FontSize="12"/>
                    <ToggleButton x:Name="ThemeToggleButton"
                                  Content="🌙 Koyu"
                                  Width="90"
                                  Click="ThemeToggle_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── Main Tab Content ─── -->
        <TabControl Grid.Row="1" Margin="12,10,12,12">
            <TabItem x:Name="TabMusteriler" Header="👤  Müşteriler">
                <views:CustomersView/>
            </TabItem>
            <TabItem Header="📈  Enstrümanlar">
                <views:AssetsView/>
            </TabItem>
            <TabItem Header="🔄  İşlemler">
                <views:TradesView/>
            </TabItem>
            <TabItem Header="💼  Portföy">
                <views:PortfolioView/>
            </TabItem>
            <TabItem Header="💰  Realized P/L">
                <views:RealizedPnLView/>
            </TabItem>
            <TabItem Header="🔔  Alarmlar">
                <views:AlarmsView/>
            </TabItem>
            <TabItem Header="📊  Dashboard">
                <views:DashboardView/>
            </TabItem>
        </TabControl>

        <!-- ─── Toast Notification Overlay ─── -->
        <Border x:Name="ToastNotificationBorder"
                Grid.RowSpan="2"
                Background="#1E293B"
                CornerRadius="10"
                Padding="18,14"
                Margin="0,0,24,28"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Visibility="Collapsed"
                Panel.ZIndex="999">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.35" Direction="270"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Border Width="36" Height="36" Background="#EF4444" CornerRadius="8" Margin="0,0,12,0">
                    <TextBlock Text="🔔" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <TextBlock x:Name="ToastMessageText"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" MaxWidth="320"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
